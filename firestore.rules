rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Authenticated users can read profiles (privacy/filtering handled client-side)
      allow read: if request.auth != null;
      
      allow write: if request.auth != null && request.auth.uid == userId
                   && (!('username' in request.resource.data) || (request.resource.data.username is string && request.resource.data.username.size() > 0 && request.resource.data.username.size() <= 30))
                   && (!('supportedTeam' in request.resource.data) || request.resource.data.supportedTeam == null || (request.resource.data.supportedTeam is string && request.resource.data.supportedTeam.size() == 2))
                   && (!('points' in request.resource.data) || (request.resource.data.points is int && request.resource.data.points >= 0))
                   && (!('streak' in request.resource.data) || request.resource.data.streak is int)
                   && (!('guruCount' in request.resource.data) || request.resource.data.guruCount is int)
                   && (!('isHidden' in request.resource.data) || request.resource.data.isHidden is bool);
      allow delete: if request.auth != null && request.auth.uid == userId;

      match /notifications/{notificationId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        // Allow write for group notifications but validate basic structure
        allow write: if request.auth != null 
                     && request.resource.data.title is string 
                     && request.resource.data.body is string
                     && request.resource.data.read == false;
      }
    }

    match /groups/{groupId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      // Normal update: only creator can change group settings
      // Special update: anyone with a valid invite can add themselves to 'members'
      allow update: if request.auth != null 
                   && (
                     (request.resource.data.creatorId == resource.data.creatorId) // Protect ownership
                     || 
                     (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) 
                      && request.resource.data.members.size() == resource.data.members.size() + 1
                      && request.auth.uid in request.resource.data.members)
                   );
      allow delete: if request.auth != null && request.auth.uid == resource.data.creatorId;
    }

    match /invites/{inviteId} {
      // Anyone with the invite ID can read it to check validity
      allow read: if true;
      
      // Only group creator can create/delete invites
      allow create: if request.auth != null 
                    && get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.creatorId == request.auth.uid;
      
      // Allow atomic increment of usesCount during join
      allow update: if request.auth != null
                    && request.resource.data.usesCount == resource.data.usesCount + 1
                    && request.resource.data.usesCount <= resource.data.maxUses
                    && (resource.data.expiresAt == null || request.time < resource.data.expiresAt);
                    
      allow delete: if request.auth != null 
                    && get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.creatorId == request.auth.uid;
    }
  }
}
